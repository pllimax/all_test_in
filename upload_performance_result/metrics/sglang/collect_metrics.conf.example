# collect_metrics 配置文件示例
# 复制此文件为 collect_metrics.conf 并根据实际情况修改
# 用法: ./collect_metrics.sh --config collect_metrics.conf 20260716

# 源目录基础路径（不包含日期部分）
SRC_BASE="/data/ascend-ci-share-pkking-sglang/tests/output/perf"

# Git仓库地址
GIT_REPO="git@github.com-pllimax:pllimax/all_test_in.git"

# Git仓库中的目标路径
GIT_TARGET_PATH="upload_performance_result/metrics/sglang"

# Git本地临时目录（可选，默认为脚本所在目录下的 .all_test_in_repo）
# GIT_LOCAL_DIR="/tmp/.all_test_in_repo"
